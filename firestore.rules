rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }
    function me() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    function isAdmin() {
      return signedIn() && me().role == 'admin';
    }
    function isApproved() {
      return signedIn()
        && (me().role == 'admin' || me().get('status', 'approved') == 'approved');
    }

    match /users/{uid} {
      allow read: if signedIn() && (request.auth.uid == uid || isAdmin());

      allow create: if signedIn()
        && request.auth.uid == uid
        && request.resource.data.role in ['student', 'company']
        && request.resource.data.status == 'pending';

      allow update: if isAdmin()
        || (signedIn()
          && request.auth.uid == uid
          && request.resource.data.role == resource.data.role
          && request.resource.data.get('status', '') == resource.data.get('status', '')
          && request.resource.data.get('email', '') == resource.data.get('email', '')
          && !request.resource.data.diff(resource.data).affectedKeys()
              .hasAny(['role', 'status', 'email']));

      allow delete: if isAdmin();
    }

    match /jobs/{jobId} {
      allow read: if signedIn();
      allow create: if isApproved()
        && me().role == 'company'
        && request.resource.data.companyId == request.auth.uid;
      allow update, delete: if isAdmin()
        || (signedIn() && resource.data.companyId == request.auth.uid);
    }

    match /applications/{appId} {
      allow read: if signedIn()
        && (isAdmin()
          || resource.data.studentId == request.auth.uid
          || resource.data.companyId == request.auth.uid);
      allow create: if isApproved()
        && me().role == 'student'
        && request.resource.data.studentId == request.auth.uid
        && request.resource.data.status == 'pending';
      allow update: if signedIn()
        && resource.data.companyId == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status']);
      allow delete: if isAdmin()
        || (signedIn()
          && (resource.data.studentId == request.auth.uid
            || resource.data.companyId == request.auth.uid));
    }
  }
}
